{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "tagline": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "description_extra": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "start_time": {
      "type": "string"
    },
    "duration": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "format": {
      "type": "string"
    },
    "people_label": {
      "type": "string"
    },
    "banner": {
      "type": "string"
    },
    "show_agenda": {
      "type": "boolean"
    },
    "show_people": {
      "type": "boolean"
    },
    "show_sponsors": {
      "type": "boolean"
    },
    "agenda": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "time": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "desc": {
            "type": "string"
          }
        },
        "required": [
          "time",
          "title",
          "desc"
        ]
      }
    },
    "people": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "photo": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "role"
        ]
      }
    },
    "sponsors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "logo": {
            "type": "string"
          },
          "large": {
            "type": "boolean"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "tagline",
    "description",
    "date",
    "start_time",
    "duration",
    "location",
    "format",
    "people_label",
    "show_agenda",
    "show_people",
    "show_sponsors"
  ]
}