{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "number": {
      "type": "number"
    },
    "description": {
      "type": "string"
    },
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "photo": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "number",
    "description"
  ]
}