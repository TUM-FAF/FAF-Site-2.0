{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "logo": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "large": {
      "type": "boolean"
    },
    "sort_order": {
      "type": "number"
    },
    "draft": {
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
