---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/sponsorship.css';

import planet from '../assets/web_elements/planet.PNG';
import logoEfes from '../assets/logos/efes.png';
import logoAmdaris from '../assets/logos/amdaris.png';
import logoAlliedTesting from '../assets/logos/allied-testing.png';
import logoUtm from '../assets/logos/utm.png';
import logoTechQuarter from '../assets/logos/tech-quarter.png';
import logoTekwill from '../assets/logos/tekwill.png';
import logoCybercor from '../assets/logos/cybercor.png';
import logoOptiplaza from '../assets/logos/optiplaza.png';
import logoPgi from '../assets/logos/pgi.png';
import logoSigmoid from '../assets/logos/sigmoid.png';
import logoFusionworks from '../assets/logos/fusionworks.png';
import logoStefanini from '../assets/logos/stefanini.png';

const partnerLogoMap: Record<string, ImageMetadata> = {
  '/assets/logos/efes.png': logoEfes,
  '/assets/logos/amdaris.png': logoAmdaris,
  '/assets/logos/allied-testing.png': logoAlliedTesting,
  '/assets/logos/utm.png': logoUtm,
  '/assets/logos/tech-quarter.png': logoTechQuarter,
  '/assets/logos/tekwill.png': logoTekwill,
  '/assets/logos/cybercor.png': logoCybercor,
  '/assets/logos/optiplaza.png': logoOptiplaza,
  '/assets/logos/pgi.png': logoPgi,
  '/assets/logos/sigmoid.png': logoSigmoid,
  '/assets/logos/fusionworks.png': logoFusionworks,
  '/assets/logos/stefanini.png': logoStefanini,
};

const allTiers = await getCollection('tiers');
const tiers = allTiers
  .filter(t => !t.data.draft)
  .sort((a, b) => (a.data.sort_order ?? 99) - (b.data.sort_order ?? 99));

const allPartners = await getCollection('partners');
const partners = allPartners
  .filter(p => !p.data.draft)
  .sort((a, b) => (a.data.sort_order ?? 99) - (b.data.sort_order ?? 99));
---

<BaseLayout bodyClass="sponsorship-page">
    <section class="sponsor-hero">
        <div class="container">
            <p class="hero-tagline">Partner with FAF</p>
            <h1>Sponsor the Future of Tech in Moldova</h1>
            <p class="hero-subtitle">
                Join the companies shaping Moldova's next generation of IT professionals.
                Choose a sponsorship tier that fits your goals and let's build something "cu tolk'".
            </p>
            <div class="hero-buttons">
                <a href="#tiers" class="btn btn-primary">View Packages</a>
                <a href="/#meeting" class="btn btn-secondary">Get in Touch</a>
            </div>
        </div>
    </section>

    <section class="why-sponsor">
        <div class="container">
            <h2>Why Sponsor FAF?</h2>
            <p class="section-subtitle">
                Our events reach hundreds of students, developers, and tech professionals across Moldova every year.
                Here's what your brand gets in return.
            </p>

            <div class="why-grid">
                <article class="why-card card-glass">
                    <h3>Brand Visibility</h3>
                    <p>Your logo on all event materials, social media shoutouts, and on‑stage mentions during our hackathons and conferences.</p>
                </article>
                <article class="why-card card-glass">
                    <h3>Talent Pipeline</h3>
                    <p>Direct access to top CS students. Recruit from hackathon winners and workshop participants before anyone else.</p>
                </article>
                <article class="why-card card-glass">
                    <h3>Community Impact</h3>
                    <p>Support education, mentorship, and gender‑inclusive programs like SheNovate that create lasting change in Moldova's tech ecosystem.</p>
                </article>
            </div>
        </div>
    </section>

    <section id="tiers" class="tiers">
        <div class="container">
            <h2>Sponsorship Packages</h2>
            <p class="section-subtitle">
                Four tiers designed to match different levels of involvement. Every partnership helps us create better events for the community.
            </p>

            <div class="tiers-grid">
                {tiers.map(tier => (
                    <article class={`tier-card card-glass tier-${tier.data.name.toLowerCase()}`}>
                        {tier.data.featured && <div class="tier-label">Most Popular</div>}
                        <div class="tier-badge">{tier.data.name}</div>
                        <p class="tier-description">{tier.data.description}</p>
                        <ul class="tier-benefits">
                            {tier.data.benefits.map(benefit => <li>{benefit}</li>)}
                        </ul>
                        <a href="/#meeting" class={`btn ${tier.data.featured ? 'btn-primary' : 'btn-secondary'} tier-cta`}>
                            {tier.data.cta_label}
                        </a>
                    </article>
                ))}
            </div>
        </div>
    </section>

    <div class="page-end-wrapper">
        <div class="planet-parallax-zone" aria-hidden="true">
            <Image src={planet} alt="" class="planet-img" data-planet-img loading="lazy" />
        </div>

        <section class="partners">
            <div class="container partners-inner">
                <h2>Companies we've worked with</h2>
                <p class="section-subtitle" style="margin-left: auto; margin-right: auto; text-align: center;">
                    Past and present partners who helped make our events possible.
                </p>

                <div class="partners-logos-row">
                    {partners.map(p => (
                        partnerLogoMap[p.data.logo]
                          ? <Image src={partnerLogoMap[p.data.logo]} alt={p.data.name} class={p.data.large ? 'logo-big' : undefined} loading="lazy" />
                          : <img src={p.data.logo} alt={p.data.name} class={p.data.large ? 'logo-big' : undefined} loading="lazy" />
                    ))}
                </div>
            </div>
        </section>
    </div>
</BaseLayout>