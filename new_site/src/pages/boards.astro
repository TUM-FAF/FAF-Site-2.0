---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/boards.css';

const allImages = import.meta.glob<{ default: ImageMetadata }>(
    '../assets/boards/**/*.{jpg,jpeg,JPG,JPEG,png,PNG}',
    { eager: true }
);

function parseMember(filename: string): { name: string; role: string } {
    const base = filename.replace(/\.[^/.]+$/, '');
    const parts = base.split(' ');
    const last = parts[parts.length - 1];
    if (/^[A-Z]{2,4}$/.test(last)) {
        return { name: parts.slice(0, -1).join(' '), role: last };
    }
    return { name: base, role: '' };
}

const ROLE_ORDER = ['CEO', 'COO', 'CFO', 'CMO', 'CPO', 'CCO', 'CLO'];

interface BoardMember {
    name: string;
    role: string;
    image: ImageMetadata;
}

interface Board {
    number: number;
    members: BoardMember[];
}

const boards: Board[] = [];

for (let i = 0; i <= 7; i++) {
    const members: BoardMember[] = [];

    for (const [path, mod] of Object.entries(allImages)) {
        const folderMatch = path.match(/board-(\d+)\//i);
        if (!folderMatch || parseInt(folderMatch[1]) !== i) continue;

        const filename = path.split('/').pop() ?? '';
        const { name, role } = parseMember(filename);
        members.push({ name, role, image: mod.default });
    }

    if (members.length === 0) continue;

    members.sort((a, b) => {
        const ai = ROLE_ORDER.indexOf(a.role);
        const bi = ROLE_ORDER.indexOf(b.role);
        return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
    });

    boards.push({ number: i, members });
}

const totalMembers = boards.reduce((sum, b) => sum + b.members.length, 0);
---

<BaseLayout>
    <!-- Hero -->
    <section class="boards-hero">
        <div class="container">
            <div class="boards-hero-content">
                <p class="hero-tagline">Our Legacy</p>
                <h1>The Boards That Built FAF</h1>
                <p class="boards-hero-subtitle">
                    Every great community is shaped by the people who gave their time to build it.
                    Here are the boards that came before — each one leaving FAF stronger than they found it.
                </p>

                <div class="boards-meta">
                    <div class="boards-stat">
                        <span class="boards-stat-num">{boards.length}</span>
                        <span class="boards-stat-label">Boards</span>
                    </div>
                    <div class="boards-stat">
                        <span class="boards-stat-num">{totalMembers}</span>
                        <span class="boards-stat-label">Members</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Timeline -->
    <section class="boards-timeline">
        <div class="container">
            <a href="/aboutUs" class="boards-back" aria-label="Back to About Us">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Back to About Us
            </a>

            <div class="timeline-inner">
                {boards.map(board => (
                    <div class="board-entry">
                        <div class="board-header">
                            <div class="board-label">
                                <span class="board-ghost-num" aria-hidden="true">
                                    {String(board.number).padStart(2, '0')}
                                </span>
                                <h2 class="board-title">Board {board.number}</h2>
                            </div>
                            <div class="board-divider" aria-hidden="true"></div>
                        </div>

                        <div class="board-members">
                            {board.members.map(member => (
                                <article class="board-card card-glass">
                                    <div class="board-avatar">
                                        <Image
                                            src={member.image}
                                            alt={member.name}
                                            width={200}
                                            height={200}
                                            loading="lazy"
                                        />
                                    </div>
                                    <p class="board-member-name">{member.name}</p>
                                    {member.role && (
                                        <p class="board-member-role">{member.role}</p>
                                    )}
                                </article>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>
</BaseLayout>
