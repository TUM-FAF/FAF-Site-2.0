---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/gallery.css';

import planet from '../assets/web_elements/planet.PNG';
import summerHack1 from '../assets/photos/summer-hack-1.JPG';
import hackaton2 from '../assets/photos/hackaton-2.JPG';
import lectures1 from '../assets/photos/lectures-1.JPG';
import shenovate1 from '../assets/photos/shenovate-1.JPG';
import movieNight1 from '../assets/photos/movie-night-1.JPG';
import programmersDay1 from '../assets/photos/programmers-day-1.JPG';

const galleryImageMap: Record<string, ImageMetadata> = {
  '/assets/photos/summer-hack-1.JPG': summerHack1,
  '/assets/photos/hackaton-2.JPG': hackaton2,
  '/assets/photos/lectures-1.JPG': lectures1,
  '/assets/photos/shenovate-1.JPG': shenovate1,
  '/assets/photos/movie-night-1.JPG': movieNight1,
  '/assets/photos/programmers-day-1.JPG': programmersDay1,
};

const allPhotos = await getCollection('gallery');
const photos = allPhotos
  .filter(p => !p.data.draft)
  .sort((a, b) => (a.data.sort_order ?? 99) - (b.data.sort_order ?? 99));
---

<BaseLayout bodyClass="gallery-page">
    <section class="gallery-intro page-title">
        <div class="container">
            <h2>Our Journey </h2>
            <p class="section-subtitle">
                Take a look at the smiles, the late-night coding sessions, and the moments that bring us together.
                Every photo tells a story of the friendships and innovations that make our community so special.
            </p>
        </div>
    </section>

    <div class="page-end-wrapper">
        <div class="planet-parallax-zone" aria-hidden="true">
            <Image src={planet} alt="" class="planet-img" data-planet-img data-planet-align="right" loading="lazy" />
        </div>

        <section class="gallery-grid-section">
            <div class="container">
                <div class="gallery-masonry distance-stage">
                    {photos.map(photo => (
                        <div class="gallery-item">
                            <div class="gallery-item__thumb">
                                {galleryImageMap[photo.data.image]
                                  ? <Image src={galleryImageMap[photo.data.image]} alt={photo.data.caption ?? photo.data.title} loading="lazy" />
                                  : <img src={photo.data.image} alt={photo.data.caption ?? photo.data.title} loading="lazy" />
                                }
                            </div>
                            <div class="gallery-item__footer">
                                <span class="gallery-item__title">{photo.data.title}</span>
                                <span class="gallery-item__arrow" aria-hidden="true">&#x2197;</span>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>
    </div>
</BaseLayout>

<script type="module" is:inline>
    import { initDistanceScroll } from '/effects/distanceScroll.js';
    initDistanceScroll();
</script>