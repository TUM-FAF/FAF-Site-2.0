---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/events.css';

const allEvents = await getCollection('events');
const pastEvents = allEvents
  .filter(e => e.id !== 'cms-test')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout bodyClass="events-page">
    <section id="registration" class="registration-section">
        <div class="card-glass registration-card-wide">
            <div class="registration-content-wrapper">
                <div class="registration-info">
                    <p class="hero-tagline">Join the Movement</p>
                    <h2>Next Event: Summer Hackathon 2026</h2>
                    <p>
                        Ready to innovate? Register for our 24-hour event on <b>June 20-21</b>.
                        Experience mentorship, collaboration, and high-energy competition.
                    </p>
                    <button id="showFormBtn" class="btn btn-primary">Open Registration Form</button>
                </div>

                <div id="registrationFormContainer" class="registration-form-wrapper" style="display: none;">
                    <form class="form registration-form">
                        <div class="form-grid">
                            <div class="form-row">
                                <label for="reg-name">Name</label>
                                <input id="reg-name" type="text" placeholder="Your name" required>
                            </div>
                            <div class="form-row">
                                <label for="reg-surname">Surname</label>
                                <input id="reg-surname" type="text" placeholder="Your surname" required>
                            </div>
                            <div class="form-row">
                                <label for="reg-email">Email Address</label>
                                <input id="reg-email" type="email" placeholder="example@mail.com" required>
                            </div>
                            <div class="form-row">
                                <label for="reg-occupation">Occupation</label>
                                <select id="reg-occupation">
                                    <option value="student">Student</option>
                                    <option value="junior">Junior Developer</option>
                                    <option value="enthusiast">IT Enthusiast</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary form-submit">Submit Registration</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <header class="page-title events-page-title">
        <div class="container">
            <h2>Past Events</h2>
            <p class="section-subtitle">A timeline of what we've built and celebrated together.</p>
        </div>
    </header>

    <div class="page-end-wrapper">
        <div class="planet-parallax-zone" aria-hidden="true">
            <img src="/assets/web_elements/planet.PNG" alt="" class="planet-img" data-planet-img data-planet-align="right">
        </div>

        <section class="events">
            <div class="event-grid-special distance-stage">
                {pastEvents.map(event => {
                    const { title, date, description, image, venue } = event.data;
                    const dateStr = date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
                    const sub = venue ? `${dateStr} · ${venue}` : dateStr;
                    return (
                        <article class="event-card-featured">
                            {image && (
                                <div class="event-card__thumb">
                                    <img src={image} alt={`${title} banner`} class="event-hero-img" />
                                </div>
                            )}
                            <div class="event-card__footer">
                                <div class="event-card__info">
                                    <h3>{title}</h3>
                                    <span class="event-card__sub">{sub}</span>
                                </div>
                                <span class="event-card__arrow" aria-hidden="true">&#x2197;</span>
                            </div>
                            <p class="event-card__desc">{description}</p>
                        </article>
                    );
                })}
            </div>
        </section>
    </div>
</BaseLayout>

<script is:inline>
    const showFormBtn = document.getElementById('showFormBtn');
    if (showFormBtn) {
        showFormBtn.addEventListener('click', function() {
            const formContainer = document.getElementById('registrationFormContainer');
            formContainer.style.display = 'block';
            this.style.display = 'none';
        });
    }
</script>
<script type="module" is:inline>
    import { initDistanceScroll } from '/effects/distanceScroll.js';
    initDistanceScroll();
</script>