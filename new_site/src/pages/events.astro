---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/events.css';
---

<BaseLayout bodyClass="events-page">
    <section id="registration" class="registration-section">
        <div class="card-glass registration-card-wide">
            <div class="registration-content-wrapper">
                <div class="registration-info">
                    <p class="hero-tagline">Join the Movement</p>
                    <h2>Next Event: Summer Hackathon 2026</h2>
                    <p>
                        Ready to innovate? Register for our 24-hour event on <b>June 20-21</b>.
                        Experience mentorship, collaboration, and high-energy competition.
                    </p>
                    <button id="showFormBtn" class="btn btn-primary">Open Registration Form</button>
                </div>

                <div id="registrationFormContainer" class="registration-form-wrapper" style="display: none;">
                    <form class="form registration-form">
                        <div class="form-grid">
                            <div class="form-row">
                                <label for="reg-name">Name</label>
                                <input id="reg-name" type="text" placeholder="Your name" required>
                            </div>
                            <div class="form-row">
                                <label for="reg-surname">Surname</label>
                                <input id="reg-surname" type="text" placeholder="Your surname" required>
                            </div>
                            <div class="form-row">
                                <label for="reg-email">Email Address</label>
                                <input id="reg-email" type="email" placeholder="example@mail.com" required>
                            </div>
                            <div class="form-row">
                                <label for="reg-occupation">Occupation</label>
                                <select id="reg-occupation">
                                    <option value="student">Student</option>
                                    <option value="junior">Junior Developer</option>
                                    <option value="enthusiast">IT Enthusiast</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary form-submit">Submit Registration</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <header class="page-title events-page-title">
        <div class="container">
            <h2>Past Events</h2>
            <p class="section-subtitle">A timeline of what we've built and celebrated together.</p>
        </div>
    </header>

    <div class="page-end-wrapper">
        <div class="planet-parallax-zone" aria-hidden="true">
            <img src="/assets/web_elements/planet.PNG" alt="" class="planet-img" data-planet-img data-planet-align="right">
        </div>

        <section class="events">
            <div class="event-grid-special distance-stage">

                <article class="event-card-featured">
                    <div class="event-card__thumb">
                        <img src="/assets/photos/XMAS-hack-2025.png" alt="XMAS Hackathon banner" class="event-hero-img">
                    </div>
                    <div class="event-card__footer">
                        <div class="event-card__info">
                            <h3>XMAS Hackathon 2025</h3>
                            <span class="event-card__sub">December 20&ndash;21, 2025 &middot; Tekwill</span>
                        </div>
                        <span class="event-card__arrow" aria-hidden="true">&#x2197;</span>
                    </div>
                    <p class="event-card__desc">The most iconic year-end FAF event. Three tracks: AI for Study Optimization, Machine Learning, Cybersecurity &mdash; each with major prizes.</p>
                </article>

                <article class="event-card-featured">
                    <div class="event-card__thumb">
                        <img src="/assets/photos/programmers-day.png" alt="Programmers Day banner" class="event-hero-img">
                    </div>
                    <div class="event-card__footer">
                        <div class="event-card__info">
                            <h3>Programmers’ Day 2025</h3>
                            <span class="event-card__sub">September 13, 2025 &middot; Tekwill</span>
                        </div>
                        <span class="event-card__arrow" aria-hidden="true">&#x2197;</span>
                    </div>
                    <p class="event-card__desc">A celebration of the 256th day of the year with a technical conference, international experts, IT quizzes, and networking.</p>
                </article>

                <article class="event-card-featured">
                    <div class="event-card__thumb">
                        <img src="/assets/photos/summer-hackathon.png" alt="Summer Hackathon banner" class="event-hero-img">
                    </div>
                    <div class="event-card__footer">
                        <div class="event-card__info">
                            <h3>Summer Hackathon 2025</h3>
                            <span class="event-card__sub">June 21&ndash;22, 2025 &middot; CyberCor</span>
                        </div>
                        <span class="event-card__arrow" aria-hidden="true">&#x2197;</span>
                    </div>
                    <p class="event-card__desc">24-hour endurance challenge. 150+ students built tech products from scratch, competing for &euro;3000 prizes per track.</p>
                </article>

                <article class="event-card-featured">
                    <div class="event-card__thumb">
                        <img src="/assets/photos/she-novate.png" alt="She-novate Conference banner" class="event-hero-img">
                    </div>
                    <div class="event-card__footer">
                        <div class="event-card__info">
                            <h3>She-novate 2025</h3>
                            <span class="event-card__sub">March 9, 2025 &middot; Tekwill</span>
                        </div>
                        <span class="event-card__arrow" aria-hidden="true">&#x2197;</span>
                    </div>
                    <p class="event-card__desc">Empowering forum for women in tech with keynotes and workshops led by industry leaders, focused on breaking gender barriers.</p>
                </article>

                <article class="event-card-featured">
                    <div class="event-card__thumb">
                        <img src="/assets/photos/XMAS-hackathon.png" alt="XMAS Hackathon banner" class="event-hero-img">
                    </div>
                    <div class="event-card__footer">
                        <div class="event-card__info">
                            <h3>XMAS Hackathon 2024</h3>
                            <span class="event-card__sub">December 21&ndash;22, 2024 &middot; Tekwill</span>
                        </div>
                        <span class="event-card__arrow" aria-hidden="true">&#x2197;</span>
                    </div>
                    <p class="event-card__desc">Holiday-themed 24h sprint on creative problem-solving. Mentors from top tech companies helped teams build functional prototypes.</p>
                </article>

                <article class="event-card-featured">
                    <div class="event-card__thumb">
                        <img src="/assets/photos/programmers-day-2024.png" alt="Programmers Day banner" class="event-hero-img">
                    </div>
                    <div class="event-card__footer">
                        <div class="event-card__info">
                            <h3>Programmers’ Day 2024</h3>
                            <span class="event-card__sub">September 12, 2024 &middot; Tekwill</span>
                        </div>
                        <span class="event-card__arrow" aria-hidden="true">&#x2197;</span>
                    </div>
                    <p class="event-card__desc">Technical talks from Amdaris and Cegeka focused on career paths, with a major networking session for students and young professionals.</p>
                </article>

                <article class="event-card-featured">
                    <div class="event-card__thumb">
                        <img src="/assets/photos/summer-hack-2024.png" alt="Summer Hackathon banner" class="event-hero-img">
                    </div>
                    <div class="event-card__footer">
                        <div class="event-card__info">
                            <h3>Summer Hackathon 2024</h3>
                            <span class="event-card__sub">June 15&ndash;16, 2024 &middot; FCIM Amphitheater</span>
                        </div>
                        <span class="event-card__arrow" aria-hidden="true">&#x2197;</span>
                    </div>
                    <p class="event-card__desc">&ldquo;Marathon of Ingenuity&rdquo; building web platforms for real-world consumer problems. Prizes from TechQuarter and Stefanini.</p>
                </article>

                <article class="event-card-featured">
                    <div class="event-card__thumb">
                        <img src="/assets/photos/xmas-hack-2023.png" alt="XMAS Hackathon banner" class="event-hero-img">
                    </div>
                    <div class="event-card__footer">
                        <div class="event-card__info">
                            <h3>XMAS Hackathon 2023</h3>
                            <span class="event-card__sub">December 23&ndash;24, 2023 &middot; Tekwill</span>
                        </div>
                        <span class="event-card__arrow" aria-hidden="true">&#x2197;</span>
                    </div>
                    <p class="event-card__desc">75 enthusiasts tackled OCR technology and automatic timetable generation. First-place prize sponsored by Allied Testing.</p>
                </article>

                <article class="event-card-featured">
                    <div class="event-card__thumb">
                        <img src="/assets/photos/programmers-day-2023.png" alt="Programmers Day banner" class="event-hero-img">
                    </div>
                    <div class="event-card__footer">
                        <div class="event-card__info">
                            <h3>Programmers’ Day 2023</h3>
                            <span class="event-card__sub">September 13, 2023 &middot; Tekwill</span>
                        </div>
                        <span class="event-card__arrow" aria-hidden="true">&#x2197;</span>
                    </div>
                    <p class="event-card__desc">Panels on AI and Web Development with guest speakers from the local IT hub and student-led project demonstrations.</p>
                </article>

                <article class="event-card-featured">
                    <div class="event-card__thumb">
                        <img src="/assets/photos/summer-hack-2023.png" alt="Summer Hackathon banner" class="event-hero-img">
                    </div>
                    <div class="event-card__footer">
                        <div class="event-card__info">
                            <h3>Summer Hackathon 2023</h3>
                            <span class="event-card__sub">June 17&ndash;18, 2023 &middot; UTM</span>
                        </div>
                        <span class="event-card__arrow" aria-hidden="true">&#x2197;</span>
                    </div>
                    <p class="event-card__desc">Sustainable tech solutions sprint with a high mentor-to-participant ratio, helping junior developers refine their product pitches.</p>
                </article>

                <article class="event-card-featured">
                    <div class="event-card__thumb">
                        <img src="/assets/photos/xmas-hack-2022.png" alt="XMAS Hackathon banner" class="event-hero-img">
                    </div>
                    <div class="event-card__footer">
                        <div class="event-card__info">
                            <h3>XMAS Hackathon 2022</h3>
                            <span class="event-card__sub">December 17&ndash;18, 2022 &middot; Tekwill</span>
                        </div>
                        <span class="event-card__arrow" aria-hidden="true">&#x2197;</span>
                    </div>
                    <p class="event-card__desc">First major post-pandemic gathering focused on Smart City concepts, game development, and hardware integration with Arduino.</p>
                </article>

            </div>
        </section>
    </div>
</BaseLayout>

<script is:inline>
    const showFormBtn = document.getElementById('showFormBtn');
    if (showFormBtn) {
        showFormBtn.addEventListener('click', function() {
            const formContainer = document.getElementById('registrationFormContainer');
            formContainer.style.display = 'block';
            this.style.display = 'none';
        });
    }
</script>
<script type="module" is:inline>
    import { initDistanceScroll } from '/effects/distanceScroll.js';
    initDistanceScroll();
</script>