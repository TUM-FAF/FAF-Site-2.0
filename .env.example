# Book a meeting form (POST endpoint, e.g. Google Apps Script Web App)
PUBLIC_FORM_ENDPOINT=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Event registration form (POST endpoint, e.g. Google Apps Script Web App)
PUBLIC_EVENT_FORM_ENDPOINT=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Matomo visit tracking (leave blank to disable; both must be set to inject the tracker)
PUBLIC_MATOMO_URL=https://your-matomo-domain/
PUBLIC_MATOMO_SITE_ID=1
