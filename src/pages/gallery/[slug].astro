---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../utils/url';
import '../../styles/gallery.css';
import '../../styles/gallery-detail.css';

export async function getStaticPaths() {
  const items = await getCollection('gallery');
  return items
    .filter(p => !p.data.draft)
    .map(photo => ({
      params: { slug: photo.id },
      props: { photo },
    }));
}

const { photo } = Astro.props;
const { title, image, description, images } = photo.data;
---

<BaseLayout bodyClass="gallery-detail-page">
  <article class="gallery-detail">

    <div class="gallery-detail__hero">
      <Image src={image} alt={title} />
    </div>

    <div class="gallery-detail__container">
      <a href={withBase('/gallery')} class="gallery-detail__back">← Back to Gallery</a>

      <header class="gallery-detail__header">
        <h1>{title}</h1>
        {description && <p class="gallery-detail__desc">{description}</p>}
      </header>

      {images && images.length > 0 && (
        <section class="gallery-detail__photos">
          <div class="gallery-detail__photo-grid">
            {images.map((src, i) => (
              <div class="gallery-detail__photo">
                <Image src={src} alt={`${title} — photo ${i + 1}`} loading="lazy" />
              </div>
            ))}
          </div>
        </section>
      )}
    </div>

  </article>
</BaseLayout>
