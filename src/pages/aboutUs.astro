---
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/about.css';
import planet from '../assets/web_elements/planet.PNG';

const allTeam = await getCollection('team');
const teamMembers = allTeam
  .filter(m => !m.data.draft)
  .sort((a, b) => (a.data.sort_order ?? 99) - (b.data.sort_order ?? 99));

const pageEntry = await getEntry('aboutPage', 'index');
const p = pageEntry?.data ?? {};

const txt = {
  intro_tagline:      p.intro_tagline      ?? "Connecting Moldova's IT Community",
  intro_heading:      p.intro_heading      ?? 'Who we are',
  intro_text:         p.intro_text         ?? 'FAF is a student-led non-profit organization dedicated to bridging the gap between university education and the IT industry in Moldova. We foster a community where passion for technology meets practical application.',
  details_heading:    p.details_heading    ?? 'Events & Governance',
  details_text:       p.details_text       ?? 'We take pride in creating high-impact events like <b>Hackathons</b>, <b>FAF Lectures</b>, <b>Workshops</b> and others. These initiatives are made possible by our dedicated boards.',
  volunteer_tagline:  p.volunteer_tagline  ?? 'Get Involved',
  volunteer_heading:  p.volunteer_heading  ?? 'Become a Volunteer',
  volunteer_text:     p.volunteer_text     ?? "Want to be part of the magic? FAF is always looking for passionate students to join our community. Whether you're interested in logistics, tech, or marketing, there's a place for you here.",
  volunteer_btn_label: p.volunteer_btn_label ?? 'Join the Team',
  team_heading:       p.team_heading       ?? 'Meet the team',
  team_subtitle:      p.team_subtitle      ?? 'The core team coordinating FAF projects and keeping the community moving forward.',
  history_heading:    p.history_heading    ?? 'Explore Our Journey',
  history_text:       p.history_text       ?? 'Want to explore the detailed history of the organization and learn about the previous boards that built our foundation?',
  history_btn_label:  p.history_btn_label  ?? 'Discover Our History',
};
---

<BaseLayout>
    <section class="about-intro">
        <div class="container">
            <div class="intro-content">
                <p class="hero-tagline">{txt.intro_tagline}</p>
                <h1>{txt.intro_heading}</h1>
                <p class="large-text">{txt.intro_text}</p>
            </div>
        </div>
    </section>

    <section class="about-details">
        <div class="container">
            <div class="card-glass details-grid">
                <div class="details-text">
                    <h2>{txt.details_heading}</h2>
                    <p set:html={txt.details_text} />
                </div>
            </div>
        </div>
    </section>

    <section id="volunteer" class="volunteer-section">
        <div class="container">
            <div class="card-glass volunteer-cta">
                <div class="volunteer-content">
                    <p class="hero-tagline">{txt.volunteer_tagline}</p>
                    <h2>{txt.volunteer_heading}</h2>
                    <p>{txt.volunteer_text}</p>
                    <a href="/#meeting" class="btn btn-primary">{txt.volunteer_btn_label}</a>
                </div>
            </div>
        </div>
    </section>

    <section id="team" class="team">
        <div class="container">
            <h2>{txt.team_heading}</h2>
            <p class="section-subtitle">{txt.team_subtitle}</p>

            <div class="team-row">
                {teamMembers.map(member => (
                    <article class="team-card card-glass">
                        <div class="avatar">
                            {member.data.photo && <Image src={member.data.photo} alt={member.data.name} loading="lazy" />}
                        </div>
                        <h3>{member.data.name}</h3>
                        <p class="team-role">{member.data.role}</p>
                        {member.data.bio && <p class="team-bio">{member.data.bio}</p>}
                    </article>
                ))}
            </div>
        </div>
    </section>

    <div class="page-end-wrapper">
        <div class="planet-parallax-zone" aria-hidden="true">
            <Image src={planet} alt="" class="planet-img" data-planet-img loading="lazy" />
        </div>

        <section class="history-cta">
            <div class="container history-cta-inner">
                <h2>{txt.history_heading}</h2>
                <p>{txt.history_text}</p>
                <a href="/boards" class="btn btn-primary">{txt.history_btn_label}</a>
            </div>
        </section>
    </div>
</BaseLayout>
