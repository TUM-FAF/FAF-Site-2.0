---
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/volunteers.css';
import planet from '../assets/web_elements/planet.PNG';

const allRoles = await getCollection('roles');
const roles = await Promise.all(
  allRoles
    .filter(r => !r.data.draft)
    .sort((a, b) => (a.data.sort_order ?? 99) - (b.data.sort_order ?? 99))
    .map(async r => ({ ...r, Content: (await render(r)).Content }))
);

import { render } from 'astro:content';

const pageEntry = await getEntry('volunteersPage', 'index');
const p = pageEntry?.data ?? {};

const txt = {
  hero_tagline:   p.hero_tagline   ?? 'Join the Movement',
  hero_heading:   p.hero_heading   ?? 'Become a FAF Volunteer',
  hero_subtitle:  p.hero_subtitle  ?? 'FAF runs on passion. Every hackathon, lecture, and community evening happens because students like you step up and make it real.',
  hero_btn1_label: p.hero_btn1_label ?? 'See Volunteer Roles',
  hero_btn2_label: p.hero_btn2_label ?? 'Apply Now',
  steps_heading:  p.steps_heading  ?? 'How It Works',
  steps_subtitle: p.steps_subtitle ?? 'From application to your first event — here\'s the path to becoming a FAF volunteer.',
  steps: p.steps ?? [
    { title: 'Apply',         desc: 'Fill out a short form telling us about yourself, your skills, and which department interests you.' },
    { title: 'Meet the Team', desc: 'We\'ll invite you for a casual chat to get to know you and find the best fit for your interests.' },
    { title: 'Join a Team',   desc: 'Get placed under one of our leads — CFO, CPO, CCO, or CMO — based on your skills and interests.' },
    { title: 'Make an Impact',desc: 'Help organize hackathons, create content, design visuals, or coordinate with partners. You\'re in.' },
  ],
  roles_heading:  p.roles_heading  ?? 'Our Team Structure',
  roles_subtitle: p.roles_subtitle ?? 'FAF is led by a focused team of student leaders. Here\'s how we\'re organized — and where you could fit in.',
  perks_heading:  p.perks_heading  ?? 'Why Volunteer with FAF?',
  perks_subtitle: p.perks_subtitle ?? 'It\'s not just about helping out — it\'s about growing together.',
  perks: p.perks ?? [
    { title: 'Real Experience', desc: 'Organize events with 150+ participants, manage budgets, and work with real companies. This goes straight on your CV.' },
    { title: 'Network',         desc: 'Meet industry professionals, mentors, and fellow students who share your passion for technology.' },
    { title: 'Community',       desc: 'Movie nights, team outings, and a tight-knit group of people who actually care about what they\'re building.' },
    { title: 'Growth',          desc: 'Develop soft skills — leadership, communication, project management — in a supportive environment where mistakes are learning opportunities.' },
  ],
  cta_heading:   p.cta_heading   ?? 'Ready to join?',
  cta_text:      p.cta_text      ?? 'Applications are always open. Tell us about yourself and we\'ll find a place for you.',
  cta_btn_label: p.cta_btn_label ?? 'Apply to Volunteer',
};
---

<BaseLayout bodyClass="volunteers-page">
    <section class="vol-hero">
        <div class="container">
            <p class="hero-tagline">{txt.hero_tagline}</p>
            <h1>{txt.hero_heading}</h1>
            <p class="hero-subtitle">{txt.hero_subtitle}</p>
            <div class="hero-buttons">
                <a href="#roles" class="btn btn-primary">{txt.hero_btn1_label}</a>
                <a href="/#meeting" class="btn btn-secondary">{txt.hero_btn2_label}</a>
            </div>
        </div>
    </section>

    <section class="how-it-works">
        <div class="container">
            <h2>{txt.steps_heading}</h2>
            <p class="section-subtitle">{txt.steps_subtitle}</p>

            <div class="steps-grid">
                {txt.steps.map((step, i) => (
                    <div class="step-card card-glass">
                        <span class="step-number">{i + 1}</span>
                        <h3>{step.title}</h3>
                        <p>{step.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section id="roles" class="roles">
        <div class="container">
            <h2>{txt.roles_heading}</h2>
            <p class="section-subtitle">{txt.roles_subtitle}</p>

            <div class="roles-list">
                {roles.map(role => (
                    <div class="role-item">
                        <div class="role-header">
                            <span class="role-title">{role.data.title}</span>
                            <span class="role-arrow">&rsaquo;</span>
                        </div>
                        <div class="role-reveal">
                            {role.body?.trim() ? <role.Content /> : <p>{role.data.description}</p>}
                            {role.data.apply_link && (
                                <a href={role.data.apply_link} class="btn btn-secondary" style="margin-top: var(--space-sm);">Apply</a>
                            )}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section class="why-volunteer">
        <div class="container">
            <h2>{txt.perks_heading}</h2>
            <p class="section-subtitle">{txt.perks_subtitle}</p>

            <div class="perks-grid">
                {txt.perks.map(perk => (
                    <div class="perk-card card-glass">
                        <h3>{perk.title}</h3>
                        <p>{perk.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <div class="page-end-wrapper">
        <div class="planet-parallax-zone" aria-hidden="true">
            <Image src={planet} alt="" class="planet-img" data-planet-img loading="lazy" />
        </div>

        <section class="vol-cta-banner">
            <div class="container vol-cta-inner">
                <h2>{txt.cta_heading}</h2>
                <p>{txt.cta_text}</p>
                <a href="/#meeting" class="btn btn-primary">{txt.cta_btn_label}</a>
            </div>
        </section>
    </div>
</BaseLayout>

<script is:inline>
    document.querySelectorAll('.role-item').forEach(item => {
        item.querySelector('.role-header').addEventListener('click', () => {
            const isActive = item.classList.contains('active');
            document.querySelectorAll('.role-item').forEach(i => i.classList.remove('active'));
            if (!isActive) item.classList.add('active');
        });
    });
</script>
