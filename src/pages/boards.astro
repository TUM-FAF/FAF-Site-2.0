---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/boards.css';

const allImages = import.meta.glob<{ default: ImageMetadata }>(
    '../assets/boards/**/*.{jpg,jpeg,JPG,JPEG,png,PNG}',
    { eager: true }
);

function parseMember(filename: string): { name: string; role: string } {
    const base = filename.replace(/\.[^/.]+$/, '');
    const parts = base.split(' ');
    const last = parts[parts.length - 1];
    if (/^[A-Z]{2,4}$/.test(last)) {
        return { name: parts.slice(0, -1).join(' '), role: last };
    }
    return { name: base, role: '' };
}

const ROLE_ORDER = ['CEO', 'COO', 'CFO', 'CMO', 'CPO', 'CCO', 'CLO'];

const BOARD_DESCRIPTIONS: Record<number, string> = {
    0: "This is where it all began. Board 0 is the founding board — the small group of students who looked at Moldova's IT landscape and decided to do something about it. They created FAF NGO from nothing: no playbook, no budget, no precedent. What they did have was a shared conviction that university students deserved a bridge between their studies and the real industry. Everything you see today — the events, the community, the tradition — traces back to them.",
    1: "With the foundation in place, Board 1 took on the challenge of proving the organization could outlive its founders. They ran the first recurring events, established the internal processes that made handovers possible, and grew the volunteer base beyond a tight circle of friends. This board turned a founding idea into a functioning organization.",
    2: "Board 2 pushed FAF into the public eye. They scaled up events, forged the first meaningful partnerships with companies in Moldova's tech sector, and showed that a student-run NGO could operate at a professional level. By the end of their term, FAF had a reputation — not just a presence.",
    3: "Board 3 inherited momentum and used it. They deepened relationships with industry partners, introduced new event formats, and focused on making FAF genuinely useful to students at every stage of their studies — not just the ones already plugged into the tech world. Their term marked a shift from growth to maturity.",
    4: "Board 4 ran one of the most active periods in FAF's history. Hackathons grew in scale, lectures brought in speakers from across the region, and the volunteer pipeline became a structured path rather than an open door. They left the organization larger, better documented, and ready for what came next.",
    5: "Board 5 focused on depth over breadth. Rather than simply adding more events, they invested in the quality of each one — tighter logistics, better partnerships, stronger feedback loops. They also expanded FAF's internal roles, bringing in dedicated people for community and product, which gave the org the capacity to think beyond the next event.",
    6: "Board 6 carried FAF through a period of change in the broader tech environment in Moldova and kept the organization not just stable but relevant. They modernized how FAF communicated with its community, strengthened ties with alumni, and set up the structures that would allow the next board to hit the ground running.",
    7: "Board 7 is the most recent chapter before the current team. They built on everything that came before and brought their own identity to it — refining what worked, rethinking what didn't, and leaving the organization in the hands of a new generation with a clear sense of what FAF stands for and where it's going.",
};

interface BoardMember {
    name: string;
    role: string;
    image: ImageMetadata;
}

interface Board {
    number: number;
    description: string;
    members: BoardMember[];
}

const boards: Board[] = [];

for (let i = 0; i <= 7; i++) {
    const members: BoardMember[] = [];

    for (const [path, mod] of Object.entries(allImages)) {
        const folderMatch = path.match(/board-(\d+)\//i);
        if (!folderMatch || parseInt(folderMatch[1]) !== i) continue;

        const filename = path.split('/').pop() ?? '';
        const { name, role } = parseMember(filename);
        members.push({ name, role, image: mod.default });
    }

    if (members.length === 0) continue;

    members.sort((a, b) => {
        const ai = ROLE_ORDER.indexOf(a.role);
        const bi = ROLE_ORDER.indexOf(b.role);
        return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
    });

    boards.push({ number: i, description: BOARD_DESCRIPTIONS[i] ?? '', members });
}

const totalMembers = boards.reduce((sum, b) => sum + b.members.length, 0);
---

<BaseLayout>
    <!-- Hero -->
    <section class="boards-hero">
        <div class="container">
            <div class="boards-hero-content">
                <p class="hero-tagline">Our Legacy</p>
                <h1>The Boards That Built FAF</h1>
                <p class="boards-hero-subtitle">
                    Every great community is shaped by the people who gave their time to build it.
                    Here are the boards that came before — each one leaving FAF stronger than they found it.
                </p>

                <div class="boards-meta">
                    <div class="boards-stat">
                        <span class="boards-stat-num">{boards.length}</span>
                        <span class="boards-stat-label">Boards</span>
                    </div>
                    <div class="boards-stat">
                        <span class="boards-stat-num">{totalMembers}</span>
                        <span class="boards-stat-label">Members</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Timeline -->
    <section class="boards-timeline">
        <div class="container">
            <a href="/aboutUs" class="boards-back" aria-label="Back to About Us">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Back to About Us
            </a>

            <div class="timeline-inner">
                {boards.map(board => (
                    <div class="board-entry">
                        <div class="board-header">
                            <div class="board-label">
                                <span class="board-ghost-num" aria-hidden="true">
                                    {String(board.number).padStart(2, '0')}
                                </span>
                                <h2 class="board-title">Board {board.number}</h2>
                            </div>
                            <div class="board-divider" aria-hidden="true"></div>
                        </div>

                        {board.description && (
                            <p class="board-description">{board.description}</p>
                        )}

                        <div class="board-members">
                            {board.members.map(member => (
                                <article class="board-card card-glass">
                                    <div class="board-avatar">
                                        <Image
                                            src={member.image}
                                            alt={member.name}
                                            width={200}
                                            height={200}
                                            loading="lazy"
                                        />
                                    </div>
                                    <p class="board-member-name">{member.name}</p>
                                    {member.role && (
                                        <p class="board-member-role">{member.role}</p>
                                    )}
                                </article>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>
</BaseLayout>
