---
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/url';
import '../styles/events.css';
import planet from '../assets/web_elements/planet.PNG';

const allEvents = await getCollection('events');
const pastEvents = allEvents
  .filter(e => e.id !== 'cms-test' && !e.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const pageEntry = await getEntry('eventsPage', 'index');
const p = pageEntry?.data ?? {};

const txt = {
  promo_tagline:   p.promo_tagline   ?? 'Join the Movement',
  promo_heading:   p.promo_heading   ?? 'Next Event: Summer Hackathon 2026',
  promo_text:      p.promo_text      ?? 'Ready to innovate? Join our 24-hour event on <b>June 20-21</b>. Experience mentorship, collaboration, and high-energy competition.',
  promo_btn_label: p.promo_btn_label ?? 'Discover More →',
  promo_btn_href:  p.promo_btn_href  ?? '/upcoming-event',
  title_heading:   p.title_heading   ?? 'Past Events',
  title_subtitle:  p.title_subtitle  ?? "A timeline of what we've built and celebrated together.",
};
---

<BaseLayout bodyClass="events-page">
    <section id="registration" class="registration-section">
        <div class="card-glass registration-card-wide">
            <div class="registration-content-wrapper">
                <div class="registration-info">
                    <p class="hero-tagline">{txt.promo_tagline}</p>
                    <h2>{txt.promo_heading}</h2>
                    <p set:html={txt.promo_text} />
                    <a href={withBase(txt.promo_btn_href)} class="btn btn-primary">{txt.promo_btn_label}</a>
                </div>
            </div>
        </div>
    </section>

    <header class="page-title events-page-title">
        <div class="container">
            <h2>{txt.title_heading}</h2>
            <p class="section-subtitle">{txt.title_subtitle}</p>
        </div>
    </header>

    <div class="page-end-wrapper">
        <div class="planet-parallax-zone" aria-hidden="true">
            <Image src={planet} alt="" class="planet-img" data-planet-img data-planet-align="right" loading="lazy" />
        </div>

        <section class="events">
            <div class="event-grid-special distance-stage">
                {pastEvents.map(event => {
                    const { title, date, description, image, venue } = event.data;
                    const dateStr = date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
                    const sub = venue ? `${dateStr} · ${venue}` : dateStr;
                    return (
                        <a href={withBase(`/events/${event.id}`)} class="event-card-link">
                            <article class="event-card-featured">
                                {image && (
                                    <div class="event-card__thumb">
                                        <Image src={image} alt={`${title} banner`} class="event-hero-img" loading="lazy" />
                                    </div>
                                )}
                                <div class="event-card__footer">
                                    <div class="event-card__info">
                                        <h3>{title}</h3>
                                        <span class="event-card__sub">{sub}</span>
                                    </div>
                                    <span class="event-card__arrow" aria-hidden="true">&#x2197;</span>
                                </div>
                                <p class="event-card__desc">{description}</p>
                            </article>
                        </a>
                    );
                })}
            </div>
        </section>
    </div>
</BaseLayout>

<script>
    import { withBase } from '../utils/url';
    const { initDistanceScroll } = await import(/* @vite-ignore */ withBase('/effects/distanceScroll.js'));
    initDistanceScroll();
</script>
