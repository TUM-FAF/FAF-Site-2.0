---
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import hero1 from '../assets/photos/hero-1.JPG';
import hero2 from '../assets/photos/hero-2.JPG';
import hero3 from '../assets/photos/hero-3.JPG';
import planet from '../assets/web_elements/planet.PNG';
import logoInstagram from '../assets/logos/instagram.png';
import logoTelegram from '../assets/logos/telegram.png';

const homeEntry = await getEntry('home', 'index');
const home = homeEntry!.data;
const formEndpoint = import.meta.env.PUBLIC_FORM_ENDPOINT ?? '';

const allPartners = await getCollection('partners');
const partners = allPartners
  .filter(p => !p.data.draft)
  .sort((a, b) => (a.data.sort_order ?? 99) - (b.data.sort_order ?? 99));

const allTestimonials = await getCollection('testimonials');
const testimonials = allTestimonials
  .filter(t => !t.data.draft)
  .sort((a, b) => (a.data.sort_order ?? 99) - (b.data.sort_order ?? 99));
const row1 = testimonials.slice(0, 3);
const row2 = testimonials.slice(3);
---

<BaseLayout>
	<section id="hero" class="hero">
		<div class="hero-inner">
			<div class="hero-text">
				<p class="hero-tagline">{home.hero_tagline}</p>
				<h1>{home.hero_title}</h1>
				<p class="hero-subtitle">{home.hero_subtitle}</p>
				<div class="hero-buttons">
					<a href="/sponsorship" class="btn btn-primary">Book a meeting</a>
					<a href="/volunteers" class="btn btn-secondary">Become a volunteer</a>
				</div>

				<div class="hero-stats">
					<div class="hero-stat">
						<span class="hero-stat-num">150+</span>
						<span class="hero-stat-lbl">Participants per event</span>
					</div>
					<div class="hero-stat">
						<span class="hero-stat-num">6</span>
						<span class="hero-stat-lbl">Events per year</span>
					</div>
					<div class="hero-stat">
						<span class="hero-stat-num">5+</span>
						<span class="hero-stat-lbl">Years running</span>
					</div>
				</div>
			</div>

			<div class="hero-visual">
				<div class="hero-next-event">
					<span class="hero-ne-label">Coming Soon</span>
					<h3 class="hero-ne-title">{home.next_event_title}</h3>
					<p class="hero-ne-body">{home.next_event_description}</p>
					<div class="hero-ne-meta">
						<span class="hero-ne-date">{home.next_event_date}</span>
						<span>·</span>
						<span>{home.next_event_location}</span>
					</div>
					<a href="/upcoming-event" class="btn btn-primary" style="margin-top: var(--space-xl); align-self: flex-start;">Discover More →</a>
				</div>
			</div>
		</div>
	</section>

	<section id="events" class="events">
		<div class="container">
			<h2>Our Events</h2>
			<p class="section-subtitle">
				We create high-impact spaces where students, mentors, and professionals learn, build, and celebrate technology together. From 24-hour technical marathons to community-led workshops, discover how we are shaping the local IT landscape.
			</p>

			<div class="events-overview">
				<div class="events-photos-col">
					<div class="ep-grid">
						<div class="ep-large">
							<Image src={hero2} alt="Students at FAF hackathon" />
						</div>
						<div class="ep-small">
							<Image src={hero1} alt="Team presenting project" />
						</div>
						<div class="ep-small">
							<Image src={hero3} alt="Mentor helping participants" />
						</div>
					</div>
				</div>
				<div class="events-list-col">
					<ul class="event-type-list">
						<li>Hackathons</li>
						<li>Technical Lectures</li>
						<li>Programmer's Day</li>
						<li>SheNovate</li>
						<li>Community Evenings</li>
					</ul>
					<a href="/events" class="btn btn-primary events-cta">View Events History</a>
				</div>
			</div>
		</div>
	</section>

	<section id="feedback" class="feedback">
		<div class="container">
			<h2>What people say</h2>
			<p class="section-subtitle">
				A few reactions from participants at our hackathons and community events.
			</p>

			<div class="feedback-grid">
				<div class="feedback-row1">
					{row1.map(t => (
						<article class="feedback-bubble">
							<p>"{t.data.quote}"</p>
							<span class="bubble-author">{t.data.author}</span>
						</article>
					))}
				</div>
				<div class="feedback-row2">
					{row2.map(t => (
						<article class="feedback-bubble">
							<p>"{t.data.quote}"</p>
							<span class="bubble-author">{t.data.author}</span>
						</article>
					))}
				</div>
			</div>
		</div>
	</section>

	<div class="page-end-wrapper page-end-home">
		<div class="planet-parallax-zone" aria-hidden="true">
			<Image src={planet} alt="" class="planet-img" data-planet-img loading="lazy" />
		</div>

		<section id="meeting" class="meeting">
			<div class="container">
				<h2>{home.meeting_heading}</h2>
				<p class=”section-subtitle”>{home.meeting_subtitle}</p>

				<form id="meeting-form" class="form" data-endpoint={formEndpoint}>
					<div class="form-grid">
						<div class="form-row">
							<label for="first_name">First Name</label>
							<input id="first_name" name="first_name" type="text" required>
						</div>
						<div class="form-row">
							<label for="last_name">Last Name</label>
							<input id="last_name" name="last_name" type="text" required>
						</div>
						<div class="form-row">
							<label for="email">Email</label>
							<input id="email" name="email" type="email" required>
						</div>
						<div class="form-row">
							<label for="company">Company / Organization</label>
							<input id="company" name="company" type="text">
						</div>
						<div class="form-row">
							<label for="role">Role</label>
							<select id="role" name="role">
								{home.meeting_roles.map(r => <option>{r}</option>)}
							</select>
						</div>
						<div class="form-row">
							<label for="purpose">Purpose</label>
							<select id="purpose" name="purpose">
								{home.meeting_purposes.map(p => <option>{p}</option>)}
							</select>
						</div>
					</div>
					{/* Honeypot — invisible to users, bots fill it in */}
					<div style="display:none" aria-hidden="true">
						<input name="_honey" tabindex="-1" autocomplete="off">
					</div>
					<div class="form-row" style="margin-top: var(--space-md);">
						<label for="note">Additional note</label>
						<textarea id="note" name="note" rows="4"
								  placeholder="Tell us how you’d like to collaborate"></textarea>
					</div>
					<p id="meeting-msg" style="display:none; margin-top: var(--space-md);"></p>
					<button type="submit" class="btn btn-primary form-submit">Send request</button>
				</form>
			</div>
		</section>

		<section id="partners" class="partners">
			<div class="container partners-inner">
				<h2>Our partners</h2>

				<div class="partners-logos-row">
					{partners.map(p => (
						p.data.logo && (
							<Image
								src={p.data.logo}
								alt={p.data.name}
								class={p.data.large ? 'logo-big' : undefined}
								loading="lazy"
							/>
						)
					))}
				</div>
			</div>
		</section>

		<section id="contact" class="contact-band">
			<div class="container contact-grid">
				<div class="contact-col">
					<h3>Contact</h3>
					<p>str. Studenților 7, birou 309<br>Chișinău, Moldova</p>
					<p>Email: faf@fcim.utm.md </p>
				</div>
				<div class="contact-col">
					<h3>Useful links</h3>
					<p><a href="#">Privacy policy</a></p>
					<p><a href="#">Code of conduct</a></p>
					<p><a href="#meeting">Partner with FAF</a></p>
				</div>
				<div class="contact-col">
					<h3>Connect with us</h3>
					<p>Follow FAF for event updates and important announcements.</p>
					<div class="contact-social">
						<a href="https://instagram.com/faf.ngo" target="_blank" rel="noreferrer">
							<Image src={logoInstagram} alt="Instagram FAF" class="social-icon" loading="lazy" />
						</a>
						<a href="https://t.me/+rE_rO1LuJdkwY2Ni" target="_blank" rel="noreferrer">
							<Image src={logoTelegram} alt="Telegram FAF" class="social-icon" loading="lazy" />
						</a>
					</div>
					<p style="margin-top: 8px; font-size: 0.85rem;">
						Telegram channel is used for important announcements.
					</p>
				</div>
			</div>
		</section>
	</div>

	<!-- FAF Invaders easter egg: Left→Right→Left→Right→Up→Down -->
	<div id="faf-invaders-overlay" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.92); align-items:center; justify-content:center;">
		<iframe
			id="faf-invaders-frame"
			src=""
			style="width:100%; height:100%; border:none;"
			allow="autoplay"
		></iframe>
	</div>

	<!-- FAF Battle easter egg: hold mascot 7 seconds -->
	<div id="faf-battle-overlay" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.92); align-items:center; justify-content:center;">
		<iframe
			id="faf-battle-frame"
			src=""
			style="width:100%; height:100%; border:none;"
			allow="autoplay"
		></iframe>
	</div>
</BaseLayout>

<script>
  (function () {
    // ── Space Invaders: Left→Right→Left→Right→Up→Down ────────────────────────
    const SEQ = ['ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','ArrowUp','ArrowDown'];
    let seqPos = 0;

    const INVADERS_URL = import.meta.env.DEV
      ? 'http://localhost:5173/'
      : '/games/space-invaders/';

    const invOverlay = document.getElementById('faf-invaders-overlay');
    const invFrame   = document.getElementById('faf-invaders-frame');

    function openInvaders() {
      invFrame.src = INVADERS_URL;
      invOverlay.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      invFrame.focus();
    }
    function closeInvaders() {
      invOverlay.style.display = 'none';
      invFrame.src = '';
      document.body.style.overflow = '';
      seqPos = 0;
    }

    // ── Battle: hold mascot 7 seconds ────────────────────────────────────────
    const BATTLE_URL = import.meta.env.DEV
      ? 'http://localhost:5174/'
      : '/games/kiki-battle/';

    const batOverlay = document.getElementById('faf-battle-overlay');
    const batFrame   = document.getElementById('faf-battle-frame');
    let holdTimer    = null;

    function openBattle() {
      // Switch mascot to mad head and silence thought bubbles
      const headEl    = document.querySelector('.mascot-head');
      const thoughtEl = document.getElementById('mascot-thought');
      const rootEl    = document.getElementById('mascot-root');
      if (headEl) { headEl.dataset.origSrc = headEl.src; headEl.src = '/assets/mascot/head_mad.png'; }
      if (thoughtEl) thoughtEl.style.display = 'none';
      if (rootEl)    rootEl.classList.remove('mascot--thought-auto');

      batFrame.src = BATTLE_URL;
      batOverlay.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      batFrame.focus();
    }
    function closeBattle() {
      // Restore mascot head and thought bubble
      const headEl    = document.querySelector('.mascot-head');
      const thoughtEl = document.getElementById('mascot-thought');
      if (headEl && headEl.dataset.origSrc) { headEl.src = headEl.dataset.origSrc; delete headEl.dataset.origSrc; }
      if (thoughtEl) thoughtEl.style.display = '';

      batOverlay.style.display = 'none';
      batFrame.src = '';
      document.body.style.overflow = '';
    }

		let holdPointerId = null;
		const cancelHold = () => { clearTimeout(holdTimer); holdTimer = null; holdPointerId = null; };

		document.addEventListener('pointerdown', (e) => {
			const target = e.target && e.target.closest ? e.target.closest('#mascot-root') : null;
			if (!target) return;
			cancelHold();
			holdPointerId = e.pointerId;
			holdTimer = setTimeout(openBattle, 7000);
		});

		document.addEventListener('pointerup', (e) => {
			if (holdPointerId !== null && e.pointerId === holdPointerId) cancelHold();
		});
		document.addEventListener('pointercancel', (e) => {
			if (holdPointerId !== null && e.pointerId === holdPointerId) cancelHold();
		});

    // ── Shared keyboard handler ───────────────────────────────────────────────
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        if (invOverlay.style.display !== 'none') { closeInvaders(); return; }
        if (batOverlay.style.display !== 'none') { closeBattle();   return; }
      }
      if (SEQ[seqPos] === e.key) {
        seqPos++;
        if (seqPos === SEQ.length) { openInvaders(); seqPos = 0; }
      } else {
        seqPos = (SEQ[0] === e.key) ? 1 : 0;
      }
    });

    window.addEventListener('message', function (e) {
      if (e.data && e.data.type === 'exitGame') {
        if (invOverlay.style.display !== 'none') closeInvaders();
        else if (batOverlay.style.display !== 'none') closeBattle();
      }
    });
  })();

  // Meeting form submission
  (function () {
    var form = document.getElementById('meeting-form');
    if (!form) return;
    var endpoint = form.dataset.endpoint;
    var msg = document.getElementById('meeting-msg');
    var btn = form.querySelector('[type="submit"]');

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      // Honeypot check — silent drop if bot filled it in
      if (form.elements['_honey'] && form.elements['_honey'].value) return;

      if (!endpoint) {
        msg.style.display = '';
        msg.style.color = '#f87171';
        msg.textContent = 'Form endpoint not configured.';
        return;
      }

      var data = {
        first_name: form.elements['first_name'].value,
        last_name:  form.elements['last_name'].value,
        email:      form.elements['email'].value,
        company:    form.elements['company'].value,
        role:       form.elements['role'].value,
        purpose:    form.elements['purpose'].value,
        note:       form.elements['note'].value,
      };

      btn.disabled = true;
      btn.textContent = 'Sending…';
      msg.style.display = 'none';

      // no-cors because Apps Script doesn't return CORS headers
      fetch(endpoint, { method: 'POST', mode: 'no-cors', body: JSON.stringify(data) })
        .then(function () {
          form.reset();
          msg.style.display = '';
          msg.style.color = 'var(--accent)';
          msg.textContent = "Thanks! We'll be in touch soon.";
        })
        .catch(function () {
          msg.style.display = '';
          msg.style.color = '#f87171';
          msg.textContent = 'Something went wrong — please try again or email us directly.';
        })
        .finally(function () {
          btn.disabled = false;
          btn.textContent = 'Send request';
        });
    });
  })();

</script>