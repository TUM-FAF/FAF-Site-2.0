---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/upcoming-event.css';
import bannerImg from '../assets/photos/summer-hack-2024.png';
import amdaris from '../assets/logos/amdaris.png';
import efes from '../assets/logos/efes.png';
import sigmoid from '../assets/logos/sigmoid.png';
import tekwill from '../assets/logos/tekwill.png';
import alliedTesting from '../assets/logos/allied-testing.png';

const event = {
    title: 'Summer Hackathon 2026',
    tagline: 'Upcoming Event',
    description: `Summer Hackathon 2026 is FAF NGO's flagship annual event — a high-energy 24-hour coding sprint where students, designers, and innovators team up to solve real-world challenges. Expect late-night coding sessions, expert mentorship, great prizes, and a whole lot of camaraderie.`,
    descriptionExtra: `Whether you're a first-year student writing your first lines of code or a seasoned developer hunting for a new challenge, Summer Hackathon 2026 has a place for you. Teams of up to four compete across four tracks: HealthTech, FinTech, EdTech, and Open Innovation.`,
    date: 'June 20–21, 2026',
    startTime: '10:00 AM',
    duration: '24 hours',
    location: 'Technical University of Moldova, Block of Study No. 1',
    address: 'Str. Studențești 9/7, Chișinău, MD-2045',
    format: 'In-person',
    peopleLabel: 'Mentors',   // change to 'Speakers', 'Judges', 'Speakers & Mentors', etc.
};

const agenda = [
    { time: '09:30', title: 'Registration & Check-in', desc: 'Pick up your badge, find your team table, and grab some coffee.' },
    { time: '10:00', title: 'Opening Ceremony', desc: 'Welcome words from FAF NGO, partner introductions, and track briefings.' },
    { time: '10:30', title: 'Hacking Starts', desc: 'The clock begins — 24 hours on the board. Build, iterate, and innovate.' },
    { time: '13:00', title: 'Lunch Break', desc: 'Catered lunch provided by our sponsors. Recharge and keep the momentum going.' },
    { time: '15:00', title: 'Mentor Sessions Round I', desc: 'Book 15-minute 1-on-1 slots with industry mentors to validate your approach.' },
    { time: '20:00', title: 'Dinner & Networking', desc: 'Wind down with food, music, and conversations with fellow hackers.' },
    { time: '00:00', title: 'Midnight Checkpoint', desc: 'Optional mid-point demo — share your progress and receive early feedback.' },
    { time: '07:00', title: 'Mentor Sessions Round II', desc: 'Final guidance before the submission deadline. Polish that pitch.' },
    { time: '10:00', title: 'Submission Deadline', desc: 'All projects must be submitted by 10:00 AM. No late submissions accepted.' },
    { time: '11:00', title: 'Presentations & Judging', desc: 'Each team gets 5 minutes to pitch + 3 minutes Q&A with the jury panel.' },
    { time: '14:00', title: 'Awards Ceremony & Closing', desc: 'Winners announced, prizes awarded, group photo, and farewell.' },
];

const people = [
    { name: 'Alexandra Rusu', role: 'Keynote Speaker', company: 'CEO at Amdaris Moldova', emoji: '👩‍💼' },
    { name: 'Ion Țurcanu', role: 'Mentor — FinTech', company: 'Senior Engineer at Sigmoid', emoji: '👨‍💻' },
    { name: 'Maria Popescu', role: 'Mentor — HealthTech', company: 'Product Manager at Allied Testing', emoji: '👩‍⚕️' },
    { name: 'Andrei Cojocaru', role: 'Jury Member', company: 'CTO at Tekwill', emoji: '👨‍⚖️' },
    { name: 'Elena Moraru', role: 'Mentor — EdTech', company: 'Lead Developer at PGI', emoji: '👩‍🏫' },
    { name: 'Vlad Ștefan', role: 'Mentor — Open Track', company: 'Founder at CyberCor', emoji: '🧑‍🚀' },
    { name: 'Diana Gherman', role: 'Workshop Host', company: 'UX Lead at Fusionworks', emoji: '👩‍🎨' },
    { name: 'Mihai Lungu', role: 'Jury Member', company: 'Engineering Director at Stefanini', emoji: '👨‍💼' },
];

const sponsors = [
    { name: 'Amdaris', logo: amdaris, large: true },
    { name: 'Sigmoid', logo: sigmoid, large: false },
    { name: 'Allied Testing', logo: alliedTesting, large: false },
    { name: 'Tekwill', logo: tekwill, large: false },
    { name: 'Efes Moldova', logo: efes, large: false },
];
---

<BaseLayout bodyClass="upcoming-event-page">

    <!-- ── Banner image ── -->
    <div class="ue-banner">
        <Image src={bannerImg} alt="Summer Hackathon 2025 banner" class="ue-banner__img" loading="eager" />
    </div>

    <!-- ── Event header ── -->
    <div class="ue-header">
        <div class="ue-header__inner">
            <span class="ue-hero__badge">{event.tagline}</span>
            <h1>{event.title}</h1>
            <p class="ue-header__tagline">
                A 24-hour innovation sprint for students and developers. Code, create, and compete for Moldova's future.
            </p>

            <div class="ue-hero__meta">
                <div class="ue-hero__meta-item">
                    <span class="meta-icon">📅</span>
                    <span><strong>{event.date}</strong></span>
                </div>
                <div class="ue-hero__meta-item">
                    <span class="meta-icon">🕙</span>
                    <span>Starts at <strong>{event.startTime}</strong></span>
                </div>
                <div class="ue-hero__meta-item">
                    <span class="meta-icon">⏱</span>
                    <span>Duration: <strong>{event.duration}</strong></span>
                </div>
                <div class="ue-hero__meta-item">
                    <span class="meta-icon">📍</span>
                    <span><strong>{event.location}</strong></span>
                </div>
            </div>

            <div style="margin-top: var(--space-xl); display:flex; gap:12px; flex-wrap:wrap;">
                <a href="#register" class="btn btn-primary">Register Now</a>
                <a href="#agenda" class="btn btn-secondary">View Agenda</a>
            </div>
        </div>
    </div>

    <!-- ── Body ── -->
    <div class="ue-body">

        <!-- About the Event -->
        <section class="ue-about">
            <p class="ue-section-label">About the Event</p>
            <h2>What is Summer Hackathon 2026?</h2>
            <p>{event.description}</p>
            <p>{event.descriptionExtra}</p>
        </section>

        <!-- Quick Info Cards -->
        <div class="ue-info-grid">
            <div class="ue-info-card">
                <span class="ue-info-card__icon">📍</span>
                <p class="ue-info-card__label">Location</p>
                <p class="ue-info-card__value">{event.location}</p>
                <p class="ue-info-card__sub">{event.address}</p>
            </div>
            <div class="ue-info-card">
                <span class="ue-info-card__icon">📅</span>
                <p class="ue-info-card__label">Date</p>
                <p class="ue-info-card__value">{event.date}</p>
                <p class="ue-info-card__sub">Check-in from 09:30 AM</p>
            </div>
            <div class="ue-info-card">
                <span class="ue-info-card__icon">⏱</span>
                <p class="ue-info-card__label">Duration</p>
                <p class="ue-info-card__value">{event.duration}</p>
                <p class="ue-info-card__sub">Non-stop hacking marathon</p>
            </div>
            <div class="ue-info-card">
                <span class="ue-info-card__icon">👥</span>
                <p class="ue-info-card__label">Team Size</p>
                <p class="ue-info-card__value">2 – 4 people</p>
                <p class="ue-info-card__sub">Solo participants will be matched</p>
            </div>
            <div class="ue-info-card">
                <span class="ue-info-card__icon">🏆</span>
                <p class="ue-info-card__label">Prize Pool</p>
                <p class="ue-info-card__value">5 000 MDL + Rewards</p>
                <p class="ue-info-card__sub">Across 4 category tracks</p>
            </div>
            <div class="ue-info-card">
                <span class="ue-info-card__icon">🎟️</span>
                <p class="ue-info-card__label">Format</p>
                <p class="ue-info-card__value">{event.format}</p>
                <p class="ue-info-card__sub">Meals & snacks provided</p>
            </div>
        </div>

        <hr class="ue-divider" />

        <!-- Agenda -->
        <section class="ue-agenda" id="agenda">
            <p class="ue-section-label">Schedule</p>
            <h2>Event Agenda</h2>

            <div class="ue-timeline">
                {agenda.map(item => (
                    <div class="ue-timeline__item">
                        <p class="ue-timeline__time">{item.time}</p>
                        <p class="ue-timeline__title">{item.title}</p>
                        <p class="ue-timeline__desc">{item.desc}</p>
                    </div>
                ))}
            </div>
        </section>

        <hr class="ue-divider" />

        <!-- Speakers & Mentors -->
        <section class="ue-people">
            <p class="ue-section-label">{event.peopleLabel}</p>
            <h2>Who You'll Meet</h2>

            <div class="ue-people-grid">
                {people.map(person => (
                    <div class="ue-person-card">
                        <div class="ue-person-card__avatar">
                            {person.emoji}
                        </div>
                        <p class="ue-person-card__name">{person.name}</p>
                        <p class="ue-person-card__role">{person.role}</p>
                        <p class="ue-person-card__company">{person.company}</p>
                    </div>
                ))}
            </div>
        </section>

        <hr class="ue-divider" />

        <!-- Sponsors -->
        <section class="ue-sponsors">
            <p class="ue-section-label">Our Sponsors</p>
            <h2>Made Possible By</h2>
            <p class="ue-sponsors__intro">
                Summer Hackathon 2026 is powered by industry partners who believe in Moldova's next generation of tech talent.
            </p>

            <div class="ue-sponsors-grid">
                {sponsors.map(s => (
                    <div class={`ue-sponsor-logo${s.large ? ' ue-sponsor-logo--large' : ''}`}>
                        <Image src={s.logo} alt={`${s.name} logo`} loading="lazy" />
                    </div>
                ))}
            </div>
        </section>

        <hr class="ue-divider" />

        <!-- Registration Form -->
        <section class="ue-register" id="register">
            <p class="ue-section-label">Sign Up</p>
            <h2>Register for the Event</h2>
            <p class="ue-register__subtitle">
                Spots are limited — secure your place at Summer Hackathon 2026 today. We'll send confirmation details to your email.
            </p>

            <form class="ue-register__form" id="ue-form" novalidate>
                <div class="ue-form-grid">
                    <div class="ue-form-row">
                        <label for="ue-first-name">First Name *</label>
                        <input id="ue-first-name" name="first_name" type="text" placeholder="Ion" required />
                    </div>
                    <div class="ue-form-row">
                        <label for="ue-last-name">Last Name *</label>
                        <input id="ue-last-name" name="last_name" type="text" placeholder="Popescu" required />
                    </div>
                    <div class="ue-form-row">
                        <label for="ue-email">Email Address *</label>
                        <input id="ue-email" name="email" type="email" placeholder="ion.popescu@example.com" required />
                    </div>
                    <div class="ue-form-row">
                        <label for="ue-phone">Phone Number</label>
                        <input id="ue-phone" name="phone" type="tel" placeholder="+373 6X XXX XXX" />
                    </div>
                    <div class="ue-form-row">
                        <label for="ue-occupation">Occupation *</label>
                        <select id="ue-occupation" name="occupation" required>
                            <option value="" disabled selected>Select your occupation</option>
                            <option value="student">Student</option>
                            <option value="junior">Junior Developer</option>
                            <option value="mid">Mid-level Developer</option>
                            <option value="senior">Senior Developer</option>
                            <option value="designer">Designer</option>
                            <option value="pm">Product Manager</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div class="ue-form-row ue-form-row--full">
                        <label for="ue-team">Team Name (if you have one)</label>
                        <input id="ue-team" name="team_name" type="text" placeholder="Leave blank if solo or undecided" />
                    </div>
                    <div class="ue-form-row ue-form-row--full">
                        <label for="ue-message">Anything you'd like us to know?</label>
                        <textarea id="ue-message" name="message" placeholder="Dietary needs, accessibility requirements, questions..."></textarea>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">Submit Registration</button>
            </form>

            <div class="ue-register__success" id="ue-success">
                ✅ You're registered! Check your inbox for a confirmation email. See you at Summer Hackathon 2026!
            </div>
        </section>

    </div><!-- /.ue-body -->

</BaseLayout>

<script is:inline>
    const form = document.getElementById('ue-form');
    const success = document.getElementById('ue-success');

    if (form) {
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            form.style.display = 'none';
            success.style.display = 'block';
            success.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
    }
</script>
